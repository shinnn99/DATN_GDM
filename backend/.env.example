# Path tới folder chứa artifacts (gdm_model.txt, calibrator.joblib, config.json, shap_explainer.joblib)
ARTIFACTS_DIR=./artifacts

# Supabase — để trống = mock mode (in-memory)
SUPABASE_URL=
